{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tanhaei/FedPSS/tree/main/schema/fedpss_config.schema.json",
  "title": "FedPSS Experiment Configuration Schema",
  "description": "Non-private configuration schema for FedPSS federated patient-record retrieval experiments. It mirrors the YAML configuration files used by the code.",
  "type": "object",
  "additionalProperties": false,
  "required": ["seed", "experiment", "model", "semantic_mapper", "privacy"],
  "properties": {
    "seed": {"type": "integer", "default": 42},
    "experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["n_patients", "n_hospitals", "n_rounds", "local_epochs", "batch_size", "learning_rate", "top_k"],
      "properties": {
        "n_patients": {"type": "integer", "minimum": 1},
        "n_hospitals": {"type": "integer", "minimum": 1, "default": 50},
        "n_rounds": {"type": "integer", "minimum": 1, "default": 100},
        "local_epochs": {"type": "integer", "minimum": 1},
        "batch_size": {"type": "integer", "minimum": 1},
        "learning_rate": {"type": "number", "exclusiveMinimum": 0},
        "top_k": {"type": "integer", "minimum": 1, "default": 10},
        "non_iid_strength": {"type": "number", "minimum": 0, "maximum": 1},
        "non_iid_setting": {
          "type": "string",
          "enum": ["natural_site_split", "specialty_skew", "dirichlet_label_skew", "mixed"]
        },
        "dirichlet_alpha": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["static_dim", "temporal_dim", "code_vocab_size", "semantic_dim", "hidden_dim", "embedding_dim"],
      "properties": {
        "static_dim": {"type": "integer", "minimum": 1},
        "temporal_dim": {"type": "integer", "minimum": 1},
        "code_vocab_size": {"type": "integer", "minimum": 1},
        "semantic_dim": {"type": "integer", "minimum": 1},
        "hidden_dim": {"type": "integer", "minimum": 1},
        "embedding_dim": {"type": "integer", "minimum": 1},
        "temporal_encoder": {"type": "string", "enum": ["GRU", "LSTM", "TemporalTransformer"], "default": "GRU"},
        "fusion": {"type": "string", "enum": ["attention", "concatenation", "mean_pooling"], "default": "attention"}
      }
    },
    "semantic_mapper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "model_id"],
      "properties": {
        "backend": {"type": "string", "enum": ["mock", "mock_semantic", "gemma_lora", "gemma"]},
        "model_id": {"type": "string"},
        "max_length": {"type": "integer", "minimum": 1, "default": 128},
        "batch_size": {"type": "integer", "minimum": 1, "default": 16},
        "device_map": {"type": "string", "default": "auto"},
        "dtype": {"type": "string", "default": "auto"},
        "cache_descriptors": {"type": "boolean", "default": true},
        "lora_rank": {"type": ["integer", "null"], "minimum": 1},
        "lora_alpha": {"type": ["number", "null"]}
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "clip_norm", "noise_multiplier"],
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "clip_norm": {"type": "number", "minimum": 0, "default": 1.0},
        "noise_multiplier": {"type": "number", "minimum": 0, "default": 0.5},
        "epsilon": {"type": ["number", "string", "null"], "default": 10.0},
        "delta": {"type": ["number", "string", "null"], "default": 1e-6},
        "secure_aggregation": {"type": "boolean", "default": true},
        "retrieval_governance": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["role_based_access", "audit_logging", "minimum_cohort_size", "repeated_query_monitoring", "index_isolation"]
          }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "record_schema": {"type": "string", "default": "schema/bioarc_record.schema.json"},
        "record_count": {"type": ["integer", "string"], "default": 15000000},
        "raw_images": {"type": "string", "enum": ["excluded", "future_work"], "default": "excluded"},
        "unstructured_notes": {"type": "string", "enum": ["excluded", "future_work"], "default": "excluded"},
        "augmentation": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["temporal_masking", "visit_subsampling", "descriptor_dropout", "contrastive_view_generation", "time_window_jittering", "none"]
          }
        }
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["local_index", "federated_candidate_request", "regional_embedding_index"]},
        "ann_backend": {"type": "string", "enum": ["Faiss_IndexIVFPQ", "Exact", "Other"], "default": "Faiss_IndexIVFPQ"},
        "similarity": {"type": "string", "enum": ["cosine", "euclidean", "dot_product"], "default": "cosine"}
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics": {
          "type": "array",
          "items": {"type": "string", "enum": ["Precision@10", "Recall@10", "NDCG@10", "MRR", "Latency", "CommunicationMB"]}
        },
        "privacy_stress_tests": {
          "type": "array",
          "items": {"type": "string", "enum": ["membership_inference", "gradient_inversion", "retrieval_leakage", "embedding_leakage", "rare_cohort_privacy"]}
        }
      }
    }
  }
}
